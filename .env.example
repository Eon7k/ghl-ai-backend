PORT=4000
OPTIMIZER_URL=http://localhost:5001
JWT_SECRET=your-secret-at-least-32-chars-for-production

# Required for persistent logins and data (users, campaigns, creatives, integrations)
DATABASE_URL=postgresql://user:password@host:5432/ghl_ai

# OPENAI_API_KEY=your-openai-key
# Anthropic (ad copy, split tests, and Content strategy tab — required for /content-strategy/generate)
# ANTHROPIC_API_KEY=your-anthropic-key
# Optional: override model for ad copy (default claude-haiku-4-5 in code).
# ANTHROPIC_MODEL=claude-haiku-4-5
# Content strategy defaults to Haiku unless you set this (Sonnet 3.5 snapshots were retired — use a current id from docs.anthropic.com).
# ANTHROPIC_CONTENT_STRATEGY_MODEL=claude-haiku-4-5

# Ad integrations (Meta OAuth)
# FRONTEND_URL=https://your-app.vercel.app
# BACKEND_URL=https://your-backend.onrender.com
# META_APP_ID=your-meta-app-id
# META_APP_SECRET=your-meta-app-secret
# Optional: pin Graph version (default v25.0; align with Meta App Dashboard → Settings → Advanced).
# META_GRAPH_API_VERSION=v25.0
# OAuth scopes in code include pages_manage_posts + instagram_basic + instagram_content_publish (organic Page/IG posting). After adding use cases in the Meta app, users must Connect Meta again.
#
# LinkedIn Marketing API (OAuth 2.0). Redirect URL must be: {BACKEND_URL}/integrations/linkedin/callback
# Default scopes include w_organization_social (UGC as Company Page). Override only if your app uses different approved scopes.
# If you see partnerApiPostsExternal.CREATE: your app must have a Product that includes the Posts API (not ads-only). Reconnect after scopes change.
# Set LINKEDIN_API_VERSION=YYYYMM to a version your app is approved for; try an older month if the error cites a specific contract date.
# Optional: LINKEDIN_OAUTH_SCOPES=r_ads rw_ads w_organization_social
# Optional: LINKEDIN_API_VERSION=202501
# LINKEDIN_CLIENT_ID=your-client-id
# LINKEDIN_CLIENT_SECRET=your-client-secret

# Go High Level LeadConnector — Content strategy → Social Planner CSV upload (optional overrides; keys stored per-user in DB).
# GHL_API_BASE_URL=https://services.leadconnectorhq.com
# GHL_API_VERSION=2021-07-28

# ----- Platform expansion (white-label, kits, future modules) -----
# UPLOADS_PATH=./uploads
# EXPORTS_PATH=./exports
# REPORTS_PATH=./reports
# LANDING_PAGE_BASE_DOMAIN=yourdomain.com
# Optional: Google Cloud API key with “Places API (New)” enabled — enriches Page discovery with official business website + Maps link (not Facebook; see API docs).
# GOOGLE_PLACES_API_KEY=
# Competitor watch: Meta Ad Library. If META_AD_LIBRARY_TOKEN is set, the backend uses it for ads_archive (and related calls); otherwise APP_ID|APP_SECRET from META_APP_ID + META_APP_SECRET.
# Complete Ad Library API access at https://www.facebook.com/ads/library/api — optional: OPENAI_COMPETITOR_MODEL (default gpt-4o-mini) for scan briefs.
# META_AD_LIBRARY_TOKEN=
# OPENAI_COMPETITOR_MODEL=gpt-4o-mini
# GOOGLE_ADS_TRANSPARENCY_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_NAME=
# SMTP_FROM_EMAIL=
# GHL_MASTER_WEBHOOK_URL=
