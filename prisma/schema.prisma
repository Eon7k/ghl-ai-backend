generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  experiments Experiment[]
  adAccounts  AdAccountConnection[]
}

model AdAccountConnection {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  platform      String
  accountId     String
  name          String?
  accessToken   String
  refreshToken  String?
  tokenExpiresAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  experiments   Experiment[]
}

model Experiment {
  id                 String   @id @default(cuid())
  user               User     @relation(fields: [userId], references: [id])
  userId             String
  adAccount          AdAccountConnection @relation(fields: [adAccountId], references: [id])
  adAccountId        String

  name               String
  platform           String
  status             String   // draft | running | paused | completed
  phase              String   // explore | exploit | winners_scaled

  offerDescription   String
  audienceDescription String
  brandVoice         String?

  totalDailyBudget   Float
  optimizationKpi    String
  minImpressions     Int
  minClicks          Int
  minDays            Int
  aggressiveness     String
  targetTopVariants  Int

  ghlLocationId      String?
  ghlPipelineId      String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  variants           AdVariant[]
}

model AdVariant {
  id               String   @id @default(cuid())
  experiment       Experiment @relation(fields: [experimentId], references: [id])
  experimentId     String

  headline         String
  primaryText      String
  description      String?

  creativeId       String?
  creativeUrl      String?

  platformAdId     String?
  status           String   // draft | live | paused | stopped
  currentDailyBudget Float

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  metrics          AdMetricsSnapshot[]
}

model AdMetricsSnapshot {
  id          String   @id @default(cuid())
  variant     AdVariant @relation(fields: [variantId], references: [id])
  variantId   String

  date        DateTime
  impressions Int
  clicks      Int
  conversions Int
  spend       Float

  createdAt   DateTime @default(now())

  @@unique([variantId, date])
}

