generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  /** single = one user, one account. agency = can switch between client accounts. */
  accountType  String    @default("single") // "single" | "agency"
  /** If true, this user cannot log in (used for agency-managed clients without portal access). */
  loginDisabled Boolean  @default(false)
  createdAt    DateTime  @default(now())
  experiments  Experiment[]
  creatives    Creative[]
  accounts     ConnectedAccount[]
  /** When this user is an agency: clients they can switch to. */
  agencyClients   AgencyClient[]  @relation("AgencyClients")
  /** When this user is a client: agencies that can view their data. */
  managedByAgencies AgencyClient[]  @relation("AgencyManaged")
}

model AgencyClient {
  id             String   @id @default(cuid())
  agencyUserId   String
  agencyUser     User     @relation("AgencyClients", fields: [agencyUserId], references: [id], onDelete: Cascade)
  clientUserId   String
  clientUser     User     @relation("AgencyManaged", fields: [clientUserId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  @@unique([agencyUserId, clientUserId])
}

model ConnectedAccount {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform             String   // meta | tiktok | google
  accessToken          String
  refreshToken         String?
  platformAccountId    String?
  platformAccountName  String?
  createdAt            DateTime @default(now())
}

model Experiment {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String
  platform           String
  status             String   // draft | launched
  phase              String   // setup | ...
  totalDailyBudget   Float
  prompt             String?
  variantCount       Int?
  creativesSource    String?  // ai | mix | own
  aiProvider         String?  // openai | anthropic | split
  aiCreativeCount    Int?
  creativePrompt     String?
  /** Natural-language target audience; AI converts to Meta ad set targeting at launch. */
  targetAudiencePrompt String?
  campaignGroupId    String?
  metaCampaignId     String?
  metaAdSetId        String?
  attachedCreativeIds String[] @default([]) // PostgreSQL array of creative ids
  variants           Variant[]
}

model Variant {
  id           String   @id @default(cuid())
  experimentId String
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  index        Int
  copy         String
  status       String
  imageData    String?  // base64 PNG
  aiSource     String?  // openai | anthropic
}

model Creative {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  imageData String   // base64
  createdAt DateTime @default(now())
}
